long add(long a, long b) {
    return a + b;
}

long abs(long x) {
    if (x < 0)
        return 0 - x;
    return x;
}

long sum_to(long n) {
    long sum = 0;
    for (long i = 0; i <= n; i++) {
        sum += i;
    }
    return sum;
}

long gcd(long a, long b) {
    while (b != 0) {
        long next = a - (a / b) * b;
        a = b;
        b = next;
    }
    return a;
}

long classify(long x) {
    if (x < 0)
        return -1;
    if (x == 0)
        return 0;
    return 1;
}

long main() {
    long value = sum_to(5);
    value += abs(-7);
    value += gcd(48, 18);
    return value + classify(value);
}
